services:

  gestionguias-consumidor:
    image: ladyred/gestionguias-consumidor:latest
    container_name: gestion-guias-consumidor

    ports:
      - "8082:8082"

    env_file:
      - .env.docker

    environment:
      SERVER_PORT: 8082

      RABBITMQ_HOST: host.docker.internal
      RABBITMQ_PORT: 5672
      RABBITMQ_USERNAME: "${RABBITMQ_USERNAME:?RABBITMQ_USERNAME no definido}"
      RABBITMQ_PASSWORD: "${RABBITMQ_PASSWORD:?RABBITMQ_PASSWORD no definido}"
      RABBITMQ_VHOST: "${RABBITMQ_VHOST:-/}"

    extra_hosts:
      - "host.docker.internal:host-gateway"

    volumes:
      - "/home/ubuntu/wallet:/wallet:ro"
      - "./guias:/mnt/efs/guias"

    restart: unless-stopped
